{
    auto_https disable_redirects

    # Указываем Caddy принимать PROXY protocol от Xray на порту 8080
    servers :8080 {
        listener_wrappers {
            proxy_protocol {
                timeout 2s
                allow 127.0.0.1/32
            }
        }
    }

    # Глобальная настройка доверия прокси:
    # Разрешаем Caddy доверять IP-адресам, переданным от 127.0.0.1 (от Xray)
    # Это необходимо для корректного заполнения {remote_host}
    # Поддержка static IP ranges появилась в Caddy 2.7+
    servers {
        trusted_proxies static 127.0.0.1/32
    }
}

# Блок для автоматического получения сертификатов Let's Encrypt
http://example.com, :80 {
    bind 0.0.0.0
    redir https://example.com{uri} permanent
}

# Внутренний блок, принимающий трафик от Xray (только PROXY protocol)
http://127.0.0.1:8080 {
    encode gzip zstd

    # Панель администратора
    handle_path /admin-* {
        basic_auth {
            admin $2a$14$HASHEDPASSWORD
        }
        reverse_proxy 127.0.0.1:2053 {
            header_up X-Real-IP {remote_host}
        }
    }

    # Подписки
    handle_path /sub-* {
        reverse_proxy 127.0.0.1:2096 {
            header_up X-Real-IP {remote_host}
        }
    }

    # Все остальное проксируем на Lampac (заглушку)
    handle {
        reverse_proxy 127.0.0.1:9118 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        -Server
        -X-Powered-By
    }
}
