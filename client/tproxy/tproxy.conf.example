# tproxy.sh configuration example
# Пример конфигурации tproxy.sh
#
# Save as tproxy.conf in the same directory as tproxy.sh
# Сохраните как tproxy.conf в той же директории, что и tproxy.sh

# Proxy ports (must match your Xray/sing-box inbound port)
# Порты прокси (должны совпадать с портом inbound в Xray/sing-box)
PROXY_TCP_PORT=12345
PROXY_UDP_PORT=12345

# Proxy mode: 1 = TPROXY
# Режим прокси: 1 = TPROXY
PROXY_MODE=1

# DNS hijack via TPROXY
# Перехват DNS через TPROXY
DNS_HIJACK_ENABLE=1
DNS_PORT=1053

# Block QUIC (UDP 443) — recommended with BYPASS_RU_IP
# Блокировать QUIC (UDP 443) — рекомендуется с BYPASS_RU_IP
BLOCK_QUIC=1

# Bypass Russian IPs (requires ipset kernel support)
# Обход российских IP (требуется поддержка ipset в ядре)
BYPASS_RU_IP=1

# IPv6 proxy
# Проксирование IPv6
PROXY_IPV6=0

# Per-app proxy
# Проксирование по приложениям
APP_PROXY_ENABLE=1
APP_PROXY_MODE=blacklist
BYPASS_APPS_LIST="0:com.android.systemui"

# User:group for proxy core (must match your Xray/sing-box process)
# Пользователь:группа прокси-ядра (должен совпадать с процессом Xray/sing-box)
CORE_USER_GROUP="root:net_admin"
